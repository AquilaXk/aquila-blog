# Caddy container env only (materialized to .env.caddy.prod from .env.prod).
# Key names only — never commit real secret values.
API_DOMAIN=api.example.com
MONITOR_DOMAIN=status.example.com
GRAFANA_DOMAIN=grafana.example.com
PROMETHEUS_DOMAIN=prometheus.example.com
CADDY_EMAIL=you@example.com
PROMETHEUS_BASIC_AUTH_USER=NEED_TO_SET_PROMETHEUS_BASIC_AUTH_USER
PROMETHEUS_BASIC_AUTH_HASH=NEED_TO_SET_PROMETHEUS_BASIC_AUTH_HASH
# Optional blue/green upstream overrides (defaults in Caddyfile)
# ADMIN_API_UPSTREAM=back_blue
# READ_API_UPSTREAM=back_blue
