{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://www.aquilaxk.site/legal/schemas/processor.schema.json",
  "title": "AquilaLog privacy processor registry entry",
  "type": "object",
  "required": [
    "id",
    "name",
    "role",
    "serviceType",
    "dataCategories",
    "region",
    "overseasTransfer",
    "enabledByEnv",
    "contractStatus",
    "retentionControl",
    "securityControls"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
    "name": { "type": "string", "minLength": 1 },
    "role": { "type": "string", "minLength": 1 },
    "serviceType": { "type": "string", "minLength": 1 },
    "dataCategories": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "region": { "type": "string", "minLength": 1 },
    "overseasTransfer": { "type": ["boolean", "string"] },
    "enabledByEnv": { "type": "string", "minLength": 1 },
    "contractStatus": { "type": "string", "minLength": 1 },
    "retentionControl": { "type": "string", "minLength": 1 },
    "securityControls": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "reviewRequired": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
