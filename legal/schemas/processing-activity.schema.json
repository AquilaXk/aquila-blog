{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://www.aquilaxk.site/legal/schemas/processing-activity.schema.json",
  "title": "AquilaLog privacy processing activity",
  "type": "object",
  "required": [
    "id",
    "name",
    "dataCategories",
    "dataSubjects",
    "purpose",
    "legalBasis",
    "collectionSource",
    "requiredOrOptional",
    "systemOfRecord",
    "processors",
    "overseasTransfer",
    "retentionRule",
    "destructionMethod",
    "accessRoles",
    "encryption",
    "userRightsHandler",
    "codeOwner",
    "policySectionId",
    "enabledByEnv"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
    "name": { "type": "string", "minLength": 1 },
    "dataCategories": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "dataSubjects": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "purpose": { "type": "string", "minLength": 1 },
    "legalBasis": { "type": "string", "minLength": 1 },
    "collectionSource": { "type": "string", "minLength": 1 },
    "requiredOrOptional": { "type": "string", "minLength": 1 },
    "systemOfRecord": { "type": "string", "minLength": 1 },
    "processors": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "overseasTransfer": { "type": "string", "minLength": 1 },
    "retentionRule": { "type": "string", "minLength": 1 },
    "destructionMethod": { "type": "string", "minLength": 1 },
    "accessRoles": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "encryption": { "type": "string", "minLength": 1 },
    "userRightsHandler": { "type": "string", "minLength": 1 },
    "codeOwner": { "type": "string", "minLength": 1 },
    "policySectionId": { "type": "string", "minLength": 1 },
    "enabledByEnv": { "type": "string", "minLength": 1 },
    "reviewRequired": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
