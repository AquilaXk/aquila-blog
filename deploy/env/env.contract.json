{
  "version": 1,
  "placeholderPattern": "^(?:NEED_TO|EMPTY$|change_me|change-me|.*example\\\\.com$|https://www\\\\.example\\\\.com|https://api\\\\.example\\\\.com|smtp\\\\.example\\\\.com|.*<[^>]+>.*|.*sha-<[^>]+>.*)",
  "targets": {
    "home-server-source": {
      "description": "GitHub Secret HOME_SERVER_ENV before deploy-time image injection.",
      "keys": [
        { "name": "API_DOMAIN", "kind": "hostname" },
        { "name": "MONITOR_DOMAIN", "kind": "hostname" },
        { "name": "GRAFANA_DOMAIN", "kind": "hostname" },
        { "name": "PROMETHEUS_DOMAIN", "kind": "hostname" },
        { "name": "CADDY_EMAIL", "kind": "email" },
        { "name": "CF_TUNNEL_TOKEN", "secret": true, "minLength": 12 },
        { "name": "CLOUDFLARED_IMAGE", "kind": "digest-image" },
        { "name": "AUTOHEAL_IMAGE", "kind": "digest-image", "required": false },
        { "name": "CADDY_IMAGE", "kind": "digest-image", "required": false },
        { "name": "UPTIME_KUMA_IMAGE", "kind": "digest-image", "required": false },
        { "name": "PROMETHEUS_IMAGE", "kind": "digest-image", "required": false },
        { "name": "ALERTMANAGER_IMAGE", "kind": "digest-image", "required": false },
        { "name": "POSTGRES_EXPORTER_IMAGE", "kind": "digest-image", "required": false },
        { "name": "GRAFANA_IMAGE", "kind": "digest-image", "required": false },
        { "name": "LOKI_IMAGE", "kind": "digest-image", "required": false },
        { "name": "PROMTAIL_IMAGE", "kind": "digest-image", "required": false },
        { "name": "NODE_RUNTIME_IMAGE", "kind": "digest-image", "required": false },
        { "name": "DB_IMAGE", "kind": "digest-image" },
        { "name": "REDIS_IMAGE", "kind": "digest-image", "required": false },
        { "name": "MINIO_IMAGE", "kind": "digest-image" },
        { "name": "AQUILA_EXTERNAL_STORAGE_ROOT", "kind": "safe-absolute-path", "required": false, "allowedValues": ["/mnt/aquila-blog-data"] },
        { "name": "AQUILA_BACKUP_ROOT", "kind": "safe-absolute-path", "required": false },
        { "name": "AQUILA_BACKUP_RETENTION_DAILY", "kind": "integer", "required": false, "min": 1 },
        { "name": "AQUILA_BACKUP_RETENTION_WEEKLY", "kind": "integer", "required": false, "min": 1 },
        { "name": "AQUILA_BACKUP_RETENTION_MONTHLY", "kind": "integer", "required": false, "min": 1 },
        { "name": "AQUILA_BACKUP_MIN_FREE_PERCENT", "kind": "integer", "required": false, "min": 0, "max": 99 },
        { "name": "AUTOHEAL_INTERVAL_SECONDS", "kind": "integer", "required": false },
        { "name": "AUTOHEAL_START_PERIOD_SECONDS", "kind": "integer", "required": false },
        { "name": "BACK_MEM_LIMIT", "required": false },
        { "name": "BACK_MEM_RESERVATION", "required": false },
        { "name": "BACK_READ_MEM_LIMIT", "required": false },
        { "name": "BACK_READ_MEM_RESERVATION", "required": false },
        { "name": "BACK_ADMIN_MEM_LIMIT", "required": false },
        { "name": "BACK_ADMIN_MEM_RESERVATION", "required": false },
        { "name": "BACK_WORKER_MEM_LIMIT", "required": false },
        { "name": "BACK_WORKER_MEM_RESERVATION", "required": false },
        { "name": "BACK_AUTOHEAL_ENABLED", "kind": "boolean", "required": false },
        { "name": "CUSTOM__RUNTIME__API_MODE", "required": false },
        { "name": "CUSTOM__RUNTIME__API_MODE_BLUE", "required": false },
        { "name": "CUSTOM__RUNTIME__API_MODE_GREEN", "required": false },
        { "name": "CUSTOM__RUNTIME__API_MODE_WORKER", "required": false },
        { "name": "PROMETHEUS_BASIC_AUTH_USER" },
        { "name": "PROMETHEUS_BASIC_AUTH_HASH", "secret": true, "minLength": 20 },
        { "name": "OPERATIONS_ALERT_EMAIL_TO", "kind": "email", "secret": true },
        { "name": "ALERTMANAGER_SMTP_AUTH_ENABLED", "kind": "boolean", "required": false },
        {
          "name": "ALERTMANAGER_SMTP_AUTH_USERNAME",
          "requiredWhen": { "key": "ALERTMANAGER_SMTP_AUTH_ENABLED", "equals": "true" }
        },
        {
          "name": "ALERTMANAGER_SMTP_AUTH_PASSWORD",
          "secret": true,
          "requiredWhen": { "key": "ALERTMANAGER_SMTP_AUTH_ENABLED", "equals": "true" },
          "minLength": 8
        },
        { "name": "PROMETHEUS_RETENTION_TIME", "required": false },
        { "name": "PUBLIC_EDGE_PROBE_REFRESH_MS", "kind": "integer", "required": false },
        { "name": "PUBLIC_EDGE_PROBE_REQUESTS", "kind": "integer", "required": false },
        { "name": "PUBLIC_EDGE_PROBE_LATEST_POSTS", "kind": "integer", "required": false },
        { "name": "PUBLIC_EDGE_PROBE_TIMEOUT_MS", "kind": "integer", "required": false },
        { "name": "PUBLIC_EDGE_PROBE_BASE_URL", "kind": "https-url", "required": false },
        { "name": "GRAFANA_ADMIN_USER" },
        {
          "name": "GRAFANA_ADMIN_PASSWORD",
          "secret": true,
          "minLength": 16,
          "forbiddenValues": ["change_me_grafana_password"],
          "mustDifferFrom": "GRAFANA_ADMIN_USER"
        },
        { "name": "GRAFANA_ROOT_URL", "kind": "https-url" },
        { "name": "PROD___SPRING__DATASOURCE__USERNAME" },
        { "name": "PROD___SPRING__FLYWAY__USER", "required": false },
        { "name": "PROD___SPRING__FLYWAY__PASSWORD", "secret": true, "required": false, "minLength": 8 },
        { "name": "PROD___SPRING__DATASOURCE__PASSWORD", "secret": true, "minLength": 8 },
        { "name": "PROD___POSTGRES__PASSWORD", "secret": true, "minLength": 8 },
        { "name": "PROD___SPRING__DATA__REDIS__PASSWORD", "secret": true, "minLength": 8 },
        { "name": "CUSTOM__JWT__SECRET_KEY", "secret": true, "minLength": 32 },
        { "name": "CUSTOM__ADMIN__USERNAME" },
        { "name": "CUSTOM__ADMIN__EMAIL", "kind": "email" },
        { "name": "CUSTOM__ADMIN__PASSWORD", "secret": true, "minLength": 8 },
        { "name": "CUSTOM_PROD_COOKIEDOMAIN", "kind": "hostname" },
        { "name": "CUSTOM_PROD_FRONTURL", "kind": "https-url" },
        { "name": "CUSTOM_PROD_BACKURL", "kind": "https-url" },
        { "name": "CUSTOM_PROD_DBNAME" },
        { "name": "DB_BASE_NAME", "required": false },
        { "name": "CUSTOM_PROD_REDISDATABASE", "kind": "integer" },
        { "name": "CUSTOM__REVALIDATE__URL", "kind": "https-url", "required": false },
        { "name": "CUSTOM__REVALIDATE__TOKEN", "secret": true, "required": false, "minLength": 12 },
        { "name": "CUSTOM__AI__SUMMARY__ENABLED", "kind": "boolean", "required": false },
        {
          "name": "CUSTOM__AI__SUMMARY__GEMINI__API_KEY",
          "secret": true,
          "requiredWhen": { "key": "CUSTOM__AI__SUMMARY__ENABLED", "equals": "true" },
          "minLength": 8
        },
        { "name": "CUSTOM__AI__SUMMARY__GEMINI__MODEL", "required": false },
        { "name": "SPRING__MAIL__HOST" },
        { "name": "SPRING__MAIL__PORT", "kind": "integer" },
        { "name": "SPRING__MAIL__USERNAME", "required": false },
        { "name": "SPRING__MAIL__PASSWORD", "secret": true, "required": false, "minLength": 8 },
        { "name": "SPRING__MAIL__PROPERTIES__MAIL__SMTP__AUTH", "kind": "boolean", "required": false },
        { "name": "SPRING__MAIL__PROPERTIES__MAIL__SMTP__STARTTLS__ENABLE", "kind": "boolean", "required": false },
        { "name": "CUSTOM__MEMBER__SIGNUP__MAIL_FROM", "kind": "email" },
        { "name": "CUSTOM__MEMBER__SIGNUP__MAIL_SUBJECT", "required": false },
        { "name": "CUSTOM__MEMBER__SIGNUP__VERIFY_PATH", "required": false },
        { "name": "CUSTOM__MEMBER__SIGNUP__EMAIL_EXPIRATION_SECONDS", "kind": "integer", "required": false },
        { "name": "CUSTOM__MEMBER__SIGNUP__SESSION_EXPIRATION_SECONDS", "kind": "integer", "required": false },
        { "name": "MINIO_ROOT_USER" },
        { "name": "MINIO_ROOT_PASSWORD", "secret": true, "minLength": 8 },
        { "name": "CUSTOM_STORAGE_ENABLED", "kind": "boolean" },
        { "name": "CUSTOM_STORAGE_ENDPOINT", "kind": "url", "requiredWhen": { "key": "CUSTOM_STORAGE_ENABLED", "equals": "true" } },
        { "name": "CUSTOM_STORAGE_REGION", "required": false },
        { "name": "CUSTOM_STORAGE_BUCKET", "requiredWhen": { "key": "CUSTOM_STORAGE_ENABLED", "equals": "true" } },
        { "name": "CUSTOM_STORAGE_ACCESSKEY", "secret": true, "requiredWhen": { "key": "CUSTOM_STORAGE_ENABLED", "equals": "true" } },
        { "name": "CUSTOM_STORAGE_SECRETKEY", "secret": true, "requiredWhen": { "key": "CUSTOM_STORAGE_ENABLED", "equals": "true" }, "minLength": 8 },
        { "name": "CUSTOM_STORAGE_PATHSTYLEACCESS", "kind": "boolean", "required": false },
        { "name": "CUSTOM_STORAGE_KEYPREFIX", "required": false },
        { "name": "CUSTOM_STORAGE_MAXFILESIZEBYTES", "kind": "integer", "required": false, "min": 1 },
        { "name": "CUSTOM_STORAGE_CLOUD_DOCUMENT_MAXFILESIZEBYTES", "kind": "integer", "required": false, "min": 1 },
        { "name": "CUSTOM_STORAGE_CLOUD_PHOTO_MAXFILESIZEBYTES", "kind": "integer", "required": false, "min": 1 },
        { "name": "CUSTOM_STORAGE_CLOUD_ARCHIVE_MAXFILESIZEBYTES", "kind": "integer", "required": false, "min": 1 },
        { "name": "CUSTOM_STORAGE_CLOUD_VIDEO_MAXFILESIZEBYTES", "kind": "integer", "required": false, "min": 1 },
        { "name": "CUSTOM_STORAGE_CLOUD_VIDEO_RESUMABLE_MAXFILESIZEBYTES", "kind": "integer", "required": false, "min": 1 },
        { "name": "CUSTOM_STORAGE_CLOUD_VIDEO_RESUMABLE_PARTSIZEBYTES", "kind": "integer", "required": false, "min": 5242880 },
        { "name": "CUSTOM_STORAGE_CLOUD_VIDEO_RESUMABLE_EXPIRESSECONDS", "kind": "integer", "required": false, "min": 60 },
        { "name": "CUSTOM_STORAGE_MULTIPART_MAX_FILE_SIZE", "required": false },
        { "name": "CUSTOM_STORAGE_MULTIPART_MAX_REQUEST_SIZE", "required": false },
        { "name": "BACKEND_PROXY_MAX_BODY_BYTES", "kind": "integer", "required": false, "min": 1 },
        { "name": "BACKEND_PROXY_MAX_IN_FLIGHT_BODY_BYTES", "kind": "integer", "required": false, "min": 1 }
      ],
      "crossChecks": [
        { "type": "urlHostEquals", "urlKey": "CUSTOM_PROD_BACKURL", "hostKey": "API_DOMAIN" },
        { "type": "cookieDomainCovers", "domainKey": "CUSTOM_PROD_COOKIEDOMAIN", "urlKey": "CUSTOM_PROD_FRONTURL" },
        {
          "type": "pathWithin",
          "parentKey": "AQUILA_EXTERNAL_STORAGE_ROOT",
          "childKey": "AQUILA_BACKUP_ROOT",
          "defaultParent": "/mnt/aquila-blog-data",
          "strict": true
        },
        {
          "type": "pathNotWithin",
          "parentKey": "AQUILA_EXTERNAL_STORAGE_ROOT",
          "childKey": "AQUILA_BACKUP_ROOT",
          "relativeParent": "minio",
          "defaultParent": "/mnt/aquila-blog-data"
        }
      ]
    },
    "home-server-runtime": {
      "extends": "home-server-source",
      "description": "Rendered deploy/homeserver/.env.prod after deploy-time runtime-specific backend image injection.",
      "keys": [
        { "name": "BACK_BLUE_IMAGE", "kind": "digest-image" },
        { "name": "BACK_GREEN_IMAGE", "kind": "digest-image" },
        { "name": "BACK_READ_IMAGE", "kind": "digest-image" },
        { "name": "BACK_ADMIN_IMAGE", "kind": "digest-image" },
        { "name": "BACK_WORKER_IMAGE", "kind": "digest-image" }
      ]
    },
    "front-local": {
      "description": "Ignored local frontend env generated from deployment contract.",
      "render": [
        { "name": "NEXT_PUBLIC_BACKEND_URL", "from": ["CUSTOM_PROD_BACKURL"], "fallback": "https://api.aquilaxk.site" },
        { "name": "BACKEND_INTERNAL_URL", "from": ["CUSTOM_PROD_BACKURL"], "fallback": "https://api.aquilaxk.site" },
        { "name": "BACKEND_PROXY_MAX_BODY_BYTES", "from": ["BACKEND_PROXY_MAX_BODY_BYTES"], "fallback": "109051904" },
        { "name": "BACKEND_PROXY_MAX_IN_FLIGHT_BODY_BYTES", "from": ["BACKEND_PROXY_MAX_IN_FLIGHT_BODY_BYTES"], "fallback": "268435456" },
        { "name": "NEXT_PUBLIC_SITE_URL", "from": ["CUSTOM_PROD_FRONTURL"], "fallback": "https://www.aquilaxk.site" },
        { "name": "PLAYWRIGHT_BASE_URL", "from": ["CUSTOM_PROD_FRONTURL"], "fallback": "https://www.aquilaxk.site" },
        { "name": "E2E_API_BASE_URL", "from": ["CUSTOM_PROD_BACKURL"], "fallback": "https://api.aquilaxk.site" },
        { "name": "E2E_ADMIN_EMAIL", "from": ["CUSTOM__ADMIN__EMAIL"], "fallback": "" },
        { "name": "E2E_ADMIN_PASSWORD", "from": ["CUSTOM__ADMIN__PASSWORD"], "preserve": true, "fallback": "" },
        { "name": "E2E_LIVE_ADMIN_EMAIL", "from": ["CUSTOM__ADMIN__EMAIL"], "fallback": "" },
        { "name": "E2E_LIVE_ADMIN_PASSWORD", "from": ["CUSTOM__ADMIN__PASSWORD"], "preserve": true, "fallback": "" },
        { "name": "TOKEN_FOR_REVALIDATE", "from": ["CUSTOM__REVALIDATE__TOKEN"], "preserve": true, "generate": "hex:32" },
        { "name": "UPTIME_KUMA_PROXY_ORIGIN", "template": "https://${MONITOR_DOMAIN}", "fallback": "https://status.aquilaxk.site" },
        { "name": "NEXT_PUBLIC_UPTIME_KUMA_STATUS_PATH", "fallback": "/status/aquila" },
        { "name": "NEXT_PUBLIC_UPTIME_KUMA_URL", "fallback": "/status/aquila" },
        { "name": "NEXT_PUBLIC_MONITORING_EMBED_URL", "from": ["NEXT_PUBLIC_MONITORING_EMBED_URL"], "template": "https://${GRAFANA_DOMAIN}/d/blog-overview/main?orgId=1&kiosk", "fallback": "" },
        { "name": "NEXT_PUBLIC_PROMETHEUS_URL", "from": ["NEXT_PUBLIC_PROMETHEUS_URL"], "template": "https://${PROMETHEUS_DOMAIN}", "fallback": "" },
        { "name": "NEXT_PUBLIC_LOGS_EMBED_URL", "from": ["NEXT_PUBLIC_LOGS_EMBED_URL"], "fallback": "" }
      ]
    },
    "back-local": {
      "description": "Ignored local backend env generated for devInfra.",
      "render": [
        { "name": "SPRING_PROFILES_ACTIVE", "fallback": "dev" },
        { "name": "DB_BASE_NAME", "fallback": "blog" },
        { "name": "DEV_DB_PASSWORD", "preserve": true, "fallback": "dev_db_password_change_me" },
        { "name": "DEV_REDIS_PASSWORD", "preserve": true, "fallback": "dev_redis_password_change_me" },
        { "name": "DEV_MINIO_ROOT_PASSWORD", "preserve": true, "fallback": "dev_minio_password_change_me" },
        { "name": "SPRING__DATASOURCE__PASSWORD", "from": ["DEV_DB_PASSWORD"], "fallback": "dev_db_password_change_me" },
        { "name": "SPRING__DATA__REDIS__PASSWORD", "from": ["DEV_REDIS_PASSWORD"], "fallback": "dev_redis_password_change_me" },
        { "name": "CUSTOM_PROD_COOKIEDOMAIN", "from": ["CUSTOM_PROD_COOKIEDOMAIN"], "fallback": "aquilaxk.site" },
        { "name": "CUSTOM_PROD_FRONTURL", "from": ["CUSTOM_PROD_FRONTURL"], "fallback": "https://www.aquilaxk.site" },
        { "name": "CUSTOM_PROD_BACKURL", "from": ["CUSTOM_PROD_BACKURL"], "fallback": "https://api.aquilaxk.site" },
        { "name": "CUSTOM__JWT__SECRET_KEY", "from": ["CUSTOM__JWT__SECRET_KEY"], "preserve": true, "generate": "hex:48" },
        { "name": "CUSTOM__SYSTEM_MEMBER_API_KEY", "preserve": true, "generate": "hex:32" },
        { "name": "CUSTOM__ADMIN__USERNAME", "from": ["CUSTOM__ADMIN__USERNAME"], "fallback": "관리자" },
        { "name": "CUSTOM__ADMIN__EMAIL", "from": ["CUSTOM__ADMIN__EMAIL"], "fallback": "" },
        { "name": "CUSTOM__ADMIN__PASSWORD", "from": ["CUSTOM__ADMIN__PASSWORD"], "preserve": true, "fallback": "" },
        { "name": "CUSTOM__REVALIDATE__URL", "fallback": "http://localhost:3000/api/revalidate" },
        { "name": "CUSTOM__REVALIDATE__TOKEN", "from": ["CUSTOM__REVALIDATE__TOKEN"], "preserve": true, "generate": "hex:32" },
        { "name": "CUSTOM__AI__SUMMARY__ENABLED", "from": ["CUSTOM__AI__SUMMARY__ENABLED"], "fallback": "false" },
        { "name": "CUSTOM__AI__SUMMARY__GEMINI__API_KEY", "from": ["CUSTOM__AI__SUMMARY__GEMINI__API_KEY"], "fallback": "" },
        { "name": "CUSTOM__AI__SUMMARY__GEMINI__MODEL", "from": ["CUSTOM__AI__SUMMARY__GEMINI__MODEL"], "fallback": "gemini-2.5-flash" },
        { "name": "SPRING__SECURITY__OAUTH2__CLIENT__REGISTRATION__KAKAO__CLIENT_ID", "from": ["SPRING__SECURITY__OAUTH2__CLIENT__REGISTRATION__KAKAO__CLIENT_ID"], "fallback": "" }
      ]
    }
  }
}
